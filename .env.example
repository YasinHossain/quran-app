# Use the Quran.com QDC API by default (includes audio endpoints like /audio/reciters).
# Note: api.quran.com/api/v4 does NOT include QDC audio endpoints.
QURAN_API_BASE_URL=https://api.qurancdn.com/api/qdc
# Timeout (ms) for Quran API requests (server + client).
QURAN_API_TIMEOUT=10000
NEXT_PUBLIC_QURAN_API_TIMEOUT=10000
NEXT_PUBLIC_ENABLE_QURAN_PROXY=false
NEXT_PUBLIC_USE_QURAN_FOUNDATION_SEARCH=false
QURAN_PROXY_TTL_MS=60000
QURAN_PROXY_CACHE_SIZE=200
# Quran Foundation search proxy (falls back to API_GATEWAY_URL/SIGNATURE_TOKEN/INTERNAL_CLIENT_ID).
QURAN_SEARCH_API_GATEWAY_URL=
QURAN_SEARCH_SIGNATURE_TOKEN=
QURAN_SEARCH_INTERNAL_CLIENT_ID=
# Google Search Console verification code (get from https://search.google.com/search-console)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
